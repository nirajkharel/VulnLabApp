<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <Button
            android:id="@+id/btn_dump_modules"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Dump NativeModule registry" />

        <Button
            android:id="@+id/btn_exec_module"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Call SystemModule.exec('id')" />

        <Button
            android:id="@+id/btn_get_token"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Call AuthModule.getStoredToken()" />

        <TextView
            android:id="@+id/tv_output"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textIsSelectable="true"
            android:fontFamily="monospace"
            android:paddingTop="16dp" />
    </LinearLayout>
</ScrollView>
